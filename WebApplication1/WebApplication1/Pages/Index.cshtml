@page
@model IndexModel
@{
    ViewData["Title"] = "Главная";
}

<div class="text-center">
    <h1 class="display-4">Добро пожаловать в систему управления</h1>
    <p class="lead">Управляйте студентами, курсами и преподавателями эффективно.</p>
    <hr />
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
    <div class="col">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Студенты</h5>
                <p class="card-text">Просмотр, создание, редактирование и удаление записей студентов.</p>
                <a asp-page="/Students/Index" class="btn btn-primary">Перейти к студентам</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Курсы</h5>
                <p class="card-text">Управление списком доступных курсов.</p>
                <a asp-page="/Courses/Index" class="btn btn-primary">Перейти к курсам</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Преподаватели</h5>
                <p class="card-text">Управление информацией о преподавателях.</p>
                <a asp-page="/Instructors/Index" class="btn btn-primary">Перейти к преподавателям</a>
            </div>
        </div>
    </div>
</div>