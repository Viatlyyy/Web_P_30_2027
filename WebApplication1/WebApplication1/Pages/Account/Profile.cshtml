@page
@model WebApplication1.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Профиль";
}
<h1>Мой профиль</h1>
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Input.AvatarImage">Аватар</label>
                @if (!string.IsNullOrEmpty(Model.CurrentAvatarPath))
                {
                    <div class="mb-2">
                        <img src="@Model.CurrentAvatarPath" style="max-width: 150px; max-height: 150px;" class="img-thumbnail" />
                    </div>
                }
                <input asp-for="Input.AvatarImage" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="Input.AvatarImage" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Сохранить</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}