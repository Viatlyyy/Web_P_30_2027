@page
@model WebApplication1.Pages.Students.IndexModel

@{
    ViewData["Title"] = "Студенты";
}

<h1>Студенты</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Создать нового</a>
</p>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var student in Model.Students)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@student.FirstName @student.LastName</h5>
                    <p class="card-text">
                        <strong>Возраст:</strong> @student.Age<br />
                        <strong>Дата рождения:</strong> @student.DateOfBirth.ToString("yyyy-MM-dd")<br />
                        <strong>Email:</strong> @student.Email<br />
                        <strong>Имя (полное):</strong> @student.Name
                    </p>
                </div>
                <div class="card-footer bg-transparent">
                    <a asp-page="./Edit" asp-route-id="@student.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>
                    <a asp-page="./Delete" asp-route-id="@student.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                </div>
            </div>
        </div>
    }
</div>