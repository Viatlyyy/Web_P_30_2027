@page
@model WebApplication1.Pages.Students.DeleteModel
@{
    ViewData["Title"] = "Удаление студента";
}

<h1>Удаление студента</h1>
<h3>Вы уверены, что хотите удалить этого студента?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Имя</dt>
        <dd class="col-sm-10">@Model.Student!.FirstName</dd>
        <dt class="col-sm-2">Фамилия</dt>
        <dd class="col-sm-10">@Model.Student!.LastName</dd>
        <dt class="col-sm-2">Возраст</dt>
        <dd class="col-sm-10">@Model.Student!.Age</dd>
        <dt class="col-sm-2">Дата рождения</dt>
        <dd class="col-sm-10">@Model.Student!.DateOfBirth.ToShortDateString()</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Student!.Email</dd>
        <dt class="col-sm-2">Полное имя</dt>
        <dd class="col-sm-10">@Model.Student!.Name</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Student!.Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-page="./Index">Назад к списку</a>
    </form>
</div>