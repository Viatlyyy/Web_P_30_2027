@page
@model WebApplication1.Pages.Enrollments.CreateModel
@{
    ViewData["Title"] = "Записать студента на курс";
}
<h1>Записать студента на курс</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Enrollment.StudentId" class="control-label">Студент</label>
                <select asp-for="Enrollment.StudentId" class="form-control" asp-items="Model.StudentsSelectList"></select>
                <span asp-validation-for="Enrollment.StudentId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Enrollment.CourseId" class="control-label">Курс</label>
                <select asp-for="Enrollment.CourseId" class="form-control" asp-items="Model.CoursesSelectList"></select>
                <span asp-validation-for="Enrollment.CourseId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Enrollment.EnrollmentDate" class="control-label">Дата записи</label>
                <input asp-for="Enrollment.EnrollmentDate" type="date" class="form-control" />
                <span asp-validation-for="Enrollment.EnrollmentDate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Enrollment.Grade" class="control-label">Оценка (0-100)</label>
                <input asp-for="Enrollment.Grade" class="form-control" />
                <span asp-validation-for="Enrollment.Grade" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Записать" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div><a asp-page="Index">Назад к списку</a></div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}