@page
@model WebApplication1.Pages.Instructors.CreateModel

@{
    ViewData["Title"] = "Создание преподавателя";
}

<h1>Создание преподавателя</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Instructor.FirstName" class="control-label">Имя</label>
                <input asp-for="Instructor.FirstName" class="form-control" />
                <span asp-validation-for="Instructor.FirstName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Instructor.LastName" class="control-label">Фамилия</label>
                <input asp-for="Instructor.LastName" class="form-control" />
                <span asp-validation-for="Instructor.LastName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Instructor.Department" class="control-label">Отдел</label>
                <input asp-for="Instructor.Department" class="form-control" />
                <span asp-validation-for="Instructor.Department" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Instructor.Name" class="control-label">Полное имя</label>
                <input asp-for="Instructor.Name" class="form-control" />
                <span asp-validation-for="Instructor.Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Создать" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Назад к списку</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}