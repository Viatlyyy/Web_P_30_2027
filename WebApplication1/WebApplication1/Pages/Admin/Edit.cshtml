@page
@model WebApplication1.Pages.Admin.EditModel
@{
    ViewData["Title"] = "Редактирование пользователя";
}

<h1>Редактирование пользователя</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Input.Id" />
            <div class="form-group mb-3">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.FirstName"></label>
                <input asp-for="Input.FirstName" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.LastName"></label>
                <input asp-for="Input.LastName" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.Role">Роль</label>
                <select asp-for="Input.Role" class="form-control" asp-items="Model.RolesSelectList">
                    <option value="">-- Нет роли --</option>
                </select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.NewPassword">Новый пароль (оставьте пустым, если не менять)</label>
                <input asp-for="Input.NewPassword" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-page="Index" class="btn btn-secondary">Отмена</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}