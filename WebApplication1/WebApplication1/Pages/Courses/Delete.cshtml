@page
@model WebApplication1.Pages.Courses.DeleteModel
@{
    ViewData["Title"] = "Удаление курса";
}

<h1>Удаление курса</h1>
<h3>Вы уверены, что хотите удалить этот курс?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Название</dt>
        <dd class="col-sm-10">@Model.Course!.Title</dd>
        <dt class="col-sm-2">Полное название</dt>
        <dd class="col-sm-10">@Model.Course!.Name</dd>
        <dt class="col-sm-2">Преподаватель</dt>
        <dd class="col-sm-10">@(Model.Course!.Instructor != null ? $"{Model.Course.Instructor.FirstName} {Model.Course.Instructor.LastName}" : "Не назначен")</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Course!.Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-page="./Index">Назад к списку</a>
    </form>
</div>