<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="/Index">WebApplication1</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Главная</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Privacy">Конфиденциальность</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Students/Index">Студенты</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Courses/Index">Курсы</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Instructors/Index">Преподаватели</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Enrollments/Index">Записи на курсы</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Chat/Index">Чат</a></li>
                        @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Administrator"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Index">Управление пользователями</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    @(User.Identity?.Name ?? "Пользователь")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-page="/Account/Profile">Профиль</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Account/Logout">Выход</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Account/Register">Регистрация</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Account/Login">Вход</a></li>
                        }
                    </ul>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input" type="checkbox" id="themeSwitch">
                        <label class="form-check-label" for="themeSwitch">Тёмная тема</label>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebApplication1 - <a asp-page="/Privacy">Конфиденциальность</a>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/signalr.js"></script>

    <script>
        const themeSwitch = document.getElementById('themeSwitch');
        const root = document.documentElement;
        function setTheme(theme) {
            if (theme === 'dark') {
                root.setAttribute('data-bs-theme', 'dark');
                if (themeSwitch) themeSwitch.checked = true;
                localStorage.setItem('theme', 'dark');
            } else {
                root.setAttribute('data-bs-theme', 'light');
                if (themeSwitch) themeSwitch.checked = false;
                localStorage.setItem('theme', 'light');
            }
        }
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme) setTheme(storedTheme);
        else setTheme(prefersDark ? 'dark' : 'light');
        if (themeSwitch) {
            themeSwitch.addEventListener('change', (e) => setTheme(e.target.checked ? 'dark' : 'light'));
        }
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
            if (!localStorage.getItem('theme')) setTheme(e.matches ? 'dark' : 'light');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>